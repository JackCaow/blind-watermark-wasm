{
  "name": "blind-watermark-wasm",
  "version": "2.0.0",
  "description": "DWT-DCT-SVD based blind watermarking for images using WebAssembly",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build:wasm": "./build.sh",
    "build:ts": "tsup lib/index.ts --format cjs,esm --dts --clean --external ./blind_watermark.js",
    "build:copy": "node script/copy-wasm-to-dist.mjs",
    "build": "npm run build:wasm && npm run build:ts && npm run build:copy",
    "smoke": "bash script/smoke-pack.sh",
    "prepack": "npm run build:ts && npm run build:copy",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "watermark",
    "blind-watermark",
    "steganography",
    "image",
    "dwt",
    "dct",
    "svd",
    "wasm",
    "webassembly",
    "electron"
  ],
  "author": "JackCao",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JackCaow/blind-watermark-wasm.git"
  },
  "homepage": "https://JackCaow.github.io/blind-watermark-wasm/",
  "bugs": {
    "url": "https://github.com/JackCaow/blind-watermark-wasm/issues"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
